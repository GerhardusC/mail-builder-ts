{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // UGHH
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["./src/**/*"]
}
